# ===== 공통 =====
# 로컬 개발용 기본값. 운영에서는 반드시 교체.

# ===== Database (backend only) =====
# 스키마는 backend SQLAlchemy + Alembic 이 단일 출처. 프론트는 직접 접근하지 않음.
DATABASE_URL="postgresql://studylang:studylang@localhost:5433/studylang"

# ===== JWT / 인증 (backend) =====
# access/refresh 모두 HS256 서명에 사용하는 공유 시크릿. 운영에서는 32바이트 이상 랜덤.
JWT_SECRET="change-me-to-a-long-random-string"
JWT_ACCESS_TTL_SECONDS=900       # 15분
JWT_REFRESH_TTL_SECONDS=2592000  # 30일

# ===== Refresh 쿠키 (backend) =====
# 빈 문자열이면 host-only 쿠키 (localhost 같은 단일 호스트 dev에서 사용).
# 운영에선 ".lingolab.io" 같은 서브도메인 공유 도메인을 지정.
REFRESH_COOKIE_DOMAIN=""
# 운영에서는 true (HTTPS 필수). dev에서 HTTP로 작업할 땐 false.
REFRESH_COOKIE_SECURE=false

# ===== Backend (FastAPI) =====
BACKEND_HOST="0.0.0.0"
BACKEND_PORT="8001"
BACKEND_PUBLIC_URL="http://localhost:8001"

# ===== Ollama =====
OLLAMA_HOST="http://localhost:11434"
# Phase 0 sanity check 이후 확정. 후보: qwen2.5:7b-instruct, gemma2:9b
OLLAMA_MODEL="qwen2.5:7b-instruct"

# ===== 자동 마이그레이션 (backend) =====
# true: 앱 기동 시 스키마 변경 감지 → 리비전 자동 생성 + 적용 (dev 권장)
# false: 수동으로 backend/scripts/migrate.ps1 실행 (운영 권장)
AUTO_MIGRATE=true

# ===== CORS (backend) =====
# JSON 배열 형식 또는 콤마 구분 문자열 모두 허용.
CORS_ALLOW_ORIGINS="http://localhost:3000"

# ===== 프론트엔드 (Next.js) =====
NEXT_PUBLIC_BACKEND_URL="http://localhost:8001"
