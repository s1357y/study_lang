# ===== 환경 변수 =====
.env*
!.env.example

# ===== 노드 =====
node_modules/
.next/
out/
build/
dist/
.turbo/
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ===== 파이썬 =====
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
.python-version

# ===== Prisma =====
# 마이그레이션은 커밋, 생성된 클라이언트는 제외
frontend/prisma/.env

# ===== 빌드/캐시 =====
.cache/
coverage/
*.log

# ===== Claude Code =====
.claude/

# ===== OS / IDE =====
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp

# ===== 도커 볼륨 (로컬) =====
# 도커 볼륨은 named volume으로 관리되어 호스트에 노출되지 않지만,
# 혹시 모를 백업/덤프 파일은 제외
*.dump
*.sql.gz
